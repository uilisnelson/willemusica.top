  <style>
    /* ============================================================
       DESIGN TOKENS & CSS CUSTOM PROPERTIES
    ============================================================ */
    :root {
      --bg-primary:     #FFF9F2;
      --bg-secondary:   #F7F3EC;
      --petrol:         #1D4E5F;
      --petrol-light:   #2a6f85;
      --coral:          #FF7F6B;
      --coral-light:    #ff9d8d;
      --gold:           #D8A84A;
      --gold-light:     #e8bf6e;
      --graphite:       #2F3437;
      --text-primary:   #2F3437;
      --text-secondary: #5a6368;
      --text-muted:     #8a9399;
      --border:         rgba(29,78,95,0.12);
      --shadow-soft:    0 4px 32px rgba(29,78,95,0.08);
      --shadow-medium:  0 12px 48px rgba(29,78,95,0.14);
      --shadow-strong:  0 24px 80px rgba(29,78,95,0.20);
      --nav-bg:         rgba(255,249,242,0.85);
      --transition:     0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      --transition-fast:0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      --radius-organic: 62% 38% 46% 54% / 60% 44% 56% 40%;
      --font-display:   'Georgia', 'Times New Roman', serif;
      --font-body:      -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    }

    [data-theme="dark"] {
      --bg-primary:     #121416;
      --bg-secondary:   #1C2124;
      --petrol:         #3a8fa8;
      --petrol-light:   #4aadc9;
      --coral:          #ff9d8d;
      --coral-light:    #ffb5a9;
      --gold:           #e8bf6e;
      --gold-light:     #f0d08a;
      --graphite:       #e8eaeb;
      --text-primary:   #F5F5F5;
      --text-secondary: #b8c2c8;
      --text-muted:     #7a8a92;
      --border:         rgba(58,143,168,0.18);
      --shadow-soft:    0 4px 32px rgba(0,0,0,0.3);
      --shadow-medium:  0 12px 48px rgba(0,0,0,0.4);
      --shadow-strong:  0 24px 80px rgba(0,0,0,0.5);
      --nav-bg:         rgba(18,20,22,0.88);
    }

    /* ============================================================
       RESET & BASE
    ============================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      background-color: var(--bg-primary);
      color: var(--text-primary);
      font-family: var(--font-body);
      line-height: 1.65;
      overflow-x: hidden;
      transition: background-color var(--transition), color var(--transition);
    }

    img {
      display: block;
      max-width: 100%;
      height: auto;
    }

    a { text-decoration: none; color: inherit; }

    /* ============================================================
       TYPOGRAPHY
    ============================================================ */
    .font-display { font-family: var(--font-display); }

    h1, h2, h3 { line-height: 1.15; font-weight: 700; }

    .text-petrol   { color: var(--petrol); }
    .text-coral    { color: var(--coral); }
    .text-gold     { color: var(--gold); }

    /* ============================================================
       UTILITY
    ============================================================ */
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 3rem);
    }

    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }

    /* ============================================================
       PARTICLES CANVAS
    ============================================================ */
    #particles-canvas {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
      opacity: 0.35;
    }

    /* ============================================================
       NAVIGATION
    ============================================================ */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      padding: 1.25rem 0;
      transition: background var(--transition), backdrop-filter var(--transition),
                  padding var(--transition), box-shadow var(--transition);
    }

    .nav.scrolled {
      background: var(--nav-bg);
      backdrop-filter: blur(20px) saturate(1.8);
      -webkit-backdrop-filter: blur(20px) saturate(1.8);
      padding: 0.85rem 0;
      box-shadow: 0 1px 0 var(--border), var(--shadow-soft);
    }

    .nav__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .nav__logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-shrink: 0;
    }

    .nav__logo img {
      height: 44px;
      width: auto;
      transition: filter var(--transition);
    }

    [data-theme="dark"] .nav__logo img {
      filter: brightness(1.18) contrast(1.05) drop-shadow(0 0 8px rgba(58,143,168,0.3));
    }

    .nav__menu {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      list-style: none;
    }

    .nav__menu a {
      display: block;
      padding: 0.5rem 0.875rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-secondary);
      letter-spacing: 0.02em;
      border-radius: 2rem;
      transition: color var(--transition-fast), background var(--transition-fast);
      position: relative;
    }

    .nav__menu a::after {
      content: '';
      position: absolute;
      bottom: 4px; left: 50%;
      transform: translateX(-50%) scaleX(0);
      width: 16px; height: 2px;
      background: var(--coral);
      border-radius: 2px;
      transition: transform var(--transition-fast);
    }

    .nav__menu a:hover {
      color: var(--text-primary);
    }

    .nav__menu a:hover::after { transform: translateX(-50%) scaleX(1); }

    .nav__actions {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      flex-shrink: 0;
    }

    /* Theme Toggle */
    .theme-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px; height: 40px;
      border: 1.5px solid var(--border);
      border-radius: 50%;
      background: transparent;
      cursor: pointer;
      color: var(--text-secondary);
      transition: all var(--transition-fast);
      font-size: 1rem;
    }

    .theme-toggle:hover {
      border-color: var(--petrol);
      color: var(--petrol);
      background: rgba(29,78,95,0.06);
      transform: rotate(20deg);
    }

    .theme-toggle:focus-visible {
      outline: 2px solid var(--petrol);
      outline-offset: 2px;
    }

    .icon-sun, .icon-moon { display: none; }
    [data-theme="light"] .icon-sun  { display: block; }
    [data-theme="dark"]  .icon-moon { display: block; }

    /* WhatsApp Nav Button */
    .btn-nav-wa {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.55rem 1.1rem;
      background: var(--petrol);
      color: #fff;
      border-radius: 2rem;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      transition: all var(--transition-fast);
      white-space: nowrap;
    }

    .btn-nav-wa:hover {
      background: var(--petrol-light);
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(29,78,95,0.3);
    }

    .btn-nav-wa svg { flex-shrink: 0; }

    /* Hamburger */
    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 40px; height: 40px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
    }

    .hamburger span {
      display: block;
      width: 100%; height: 2px;
      background: var(--text-primary);
      border-radius: 2px;
      transition: all var(--transition-fast);
    }

    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* Mobile Nav Overlay */
    .nav__mobile {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: var(--bg-primary);
      z-index: 999;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--transition);
    }

    .nav__mobile.open {
      opacity: 1;
      pointer-events: all;
    }

    .nav__mobile a {
      font-size: clamp(1.5rem, 5vw, 2.5rem);
      font-family: var(--font-display);
      font-weight: 700;
      color: var(--text-primary);
      padding: 0.5rem 1.5rem;
      transition: color var(--transition-fast);
    }

    .nav__mobile a:hover { color: var(--coral); }

    /* ============================================================
       HERO SECTION — ASYMMETRIC
    ============================================================ */
    #inicio {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding-top: 5rem;
    }

    .hero__bg-accent {
      position: absolute;
      top: -10%;
      right: -5%;
      width: 60vw;
      height: 60vw;
      max-width: 800px;
      max-height: 800px;
      background: radial-gradient(ellipse at center,
        rgba(216,168,74,0.08) 0%,
        rgba(29,78,95,0.06) 50%,
        transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      animation: driftBg 12s ease-in-out infinite alternate;
      will-change: transform;
    }

    @keyframes driftBg {
      0%   { transform: translate(0,0) scale(1); }
      100% { transform: translate(-3%, 4%) scale(1.05); }
    }

    .hero__left {
      order:2;
      padding: clamp(2rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem) clamp(2rem, 6vw, 5rem) clamp(1.25rem, 6vw, 5rem);
      position: relative;
      z-index: 2;
    }

    .hero__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.625rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--coral);
      margin-bottom: 1.5rem;
      opacity: 0;
      transform: translateY(16px);
      animation: fadeUp 0.7s ease forwards 0.3s;
    }

    .hero__eyebrow::before {
      content: '';
      display: inline-block;
      width: 28px; height: 2px;
      background: var(--coral);
      border-radius: 2px;
    }

    .hero__title {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      font-weight: 700;
      line-height: 1.05;
      color: var(--text-primary);
      margin-bottom: 1.25rem;
      opacity: 0;
      transform: translateY(24px);
      animation: fadeUp 0.8s ease forwards 0.5s;
    }

    .hero__title em {
      font-style: normal;
      color: var(--petrol);
      position: relative;
    }

    .hero__title em::after {
      content: '';
      position: absolute;
      bottom: -4px; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--coral), var(--gold));
      border-radius: 2px;
      transform: scaleX(0);
      transform-origin: left;
      animation: underlineGrow 0.7s ease forwards 1.2s;
    }

    @keyframes underlineGrow { to { transform: scaleX(1); } }

    .hero__subtitle {
      font-size: clamp(1rem, 1.8vw, 1.2rem);
      font-weight: 500;
      color: var(--petrol);
      margin-bottom: 1rem;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.8s ease forwards 0.7s;
    }

    .hero__text {
      font-size: clamp(0.9rem, 1.4vw, 1rem);
      color: var(--text-secondary);
      max-width: 480px;
      margin-bottom: 2.5rem;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.8s ease forwards 0.9s;
    }

    .hero__ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.8s ease forwards 1.1s;
    }

    /* Sound-wave decoration */
    .hero__wave-deco {
      display: flex;
      align-items: center;
      gap: 3px;
      margin-bottom: 2rem;
      opacity: 0;
      animation: fadeIn 1s ease forwards 1.4s;
    }

    .hero__wave-deco span {
      display: block;
      width: 3px;
      background: var(--petrol);
      border-radius: 3px;
      animation: waveBounce var(--dur, 0.8s) ease-in-out infinite alternate;
      opacity: 0.45;
    }

    .hero__wave-deco span:nth-child(1)  { height: 10px; --dur: 0.9s; }
    .hero__wave-deco span:nth-child(2)  { height: 18px; --dur: 0.7s; animation-delay: 0.1s; }
    .hero__wave-deco span:nth-child(3)  { height: 28px; --dur: 1.0s; animation-delay: 0.2s; }
    .hero__wave-deco span:nth-child(4)  { height: 20px; --dur: 0.65s; animation-delay: 0.05s; }
    .hero__wave-deco span:nth-child(5)  { height: 34px; --dur: 0.85s; animation-delay: 0.15s; }
    .hero__wave-deco span:nth-child(6)  { height: 22px; --dur: 0.75s; animation-delay: 0.3s; }
    .hero__wave-deco span:nth-child(7)  { height: 14px; --dur: 0.95s; animation-delay: 0.1s; }
    .hero__wave-deco span:nth-child(8)  { height: 30px; --dur: 0.7s; animation-delay: 0.25s; }
    .hero__wave-deco span:nth-child(9)  { height: 16px; --dur: 1.1s; animation-delay: 0.35s; }
    .hero__wave-deco span:nth-child(10) { height: 8px;  --dur: 0.8s; animation-delay: 0.2s; }
    .hero__wave-deco span:nth-child(11) { height: 24px; --dur: 0.9s; animation-delay: 0.05s; }
    .hero__wave-deco span:nth-child(12) { height: 12px; --dur: 0.6s; animation-delay: 0.4s; }

    @keyframes waveBounce {
      0%   { transform: scaleY(1); }
      100% { transform: scaleY(1.6); opacity: 0.9; }
    }

    /* ============================================================
       HERO RIGHT — ORGANIC PHOTO
    ============================================================ */
    .hero__right {
      order:1;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem);
      z-index: 2;
      opacity: 0;
      animation: fadeIn 1.2s ease forwards 0.6s;
    }

    .hero__photo-wrap {
      position: relative;
      width: clamp(280px, 40vw, 520px);
    }

    .hero__photo-blob {
      width: 100%;
      aspect-ratio: 4/5;
      border-radius: 24px;
      overflow: hidden;
      
      box-shadow: var(--shadow-strong);
      position: relative;
      z-index: 2;
      will-change: transform, border-radius;
    }

    .hero__photo-blob img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
      transition: transform 8s ease;
    }

    .hero__photo-blob:hover img { transform: scale(1.04); }

    @keyframes morphShape {
      0%   { border-radius: 62% 38% 46% 54% / 60% 44% 56% 40%; }
      25%  { border-radius: 44% 56% 60% 40% / 52% 64% 36% 48%; }
      50%  { border-radius: 56% 44% 38% 62% / 48% 52% 48% 52%; }
      75%  { border-radius: 38% 62% 54% 46% / 64% 38% 62% 36%; }
      100% { border-radius: 60% 40% 44% 56% / 40% 60% 40% 60%; }
    }

    /* Decorative sound rings */
    .hero__ring {
      position: absolute;
      border-radius: 50%;
      border: 1.5px solid;
      pointer-events: none;
      animation: ringPulse var(--ring-dur, 4s) ease-in-out infinite;
    }

    .hero__ring--1 {
      width: 105%; height: 105%;
      top: -2.5%; left: -2.5%;
      border-color: rgba(216,168,74,0.25);
      --ring-dur: 4s;
    }

    .hero__ring--2 {
      width: 118%; height: 118%;
      top: -9%; left: -9%;
      border-color: rgba(29,78,95,0.15);
      --ring-dur: 5.5s;
      animation-delay: 0.8s;
    }

    .hero__ring--3 {
      width: 132%; height: 132%;
      top: -16%; left: -16%;
      border-color: rgba(255,127,107,0.1);
      --ring-dur: 7s;
      animation-delay: 1.6s;
    }

    @keyframes ringPulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50%       { transform: scale(1.03); opacity: 0.6; }
    }

    /* Floating notes */
    .hero__note {
      position: absolute;
      font-size: 1.4rem;
      animation: floatNote var(--fn-dur, 6s) ease-in-out infinite;
      opacity: 0.18;
      pointer-events: none;
      user-select: none;
    }

    .hero__note--1 { top: 8%;  right: -5%; --fn-dur: 7s; }
    .hero__note--2 { bottom: 15%; left: -8%; --fn-dur: 9s; animation-delay: 1s; }
    .hero__note--3 { top: 50%; right: -12%; --fn-dur: 6s; animation-delay: 2s; }

    @keyframes floatNote {
      0%, 100% { transform: translateY(0) rotate(-10deg); }
      50%       { transform: translateY(-18px) rotate(8deg); }
    }

    /* ============================================================
       BUTTONS
    ============================================================ */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.875rem 1.875rem;
      border-radius: 3rem;
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      transition: all var(--transition-fast);
      cursor: pointer;
      border: none;
      text-align: center;
      white-space: nowrap;
    }

    .btn:focus-visible {
      outline: 3px solid var(--coral);
      outline-offset: 3px;
    }

    .btn--primary {
      background: var(--petrol);
      color: #fff;
      box-shadow: 0 6px 24px rgba(29,78,95,0.25);
    }

    .btn--primary:hover {
      background: var(--petrol-light);
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(29,78,95,0.35);
    }

    .btn--secondary {
      background: transparent;
      color: var(--text-primary);
      border: 1.5px solid var(--border);
    }

    .btn--secondary:hover {
      border-color: var(--coral);
      color: var(--coral);
      transform: translateY(-2px);
      background: rgba(255,127,107,0.04);
    }

    .btn--coral {
      background: var(--coral);
      color: #fff;
      box-shadow: 0 6px 24px rgba(255,127,107,0.3);
    }

    .btn--coral:hover {
      background: var(--coral-light);
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(255,127,107,0.4);
    }

    .btn--ghost-white {
      background: rgba(255,255,255,0.12);
      color: #fff;
      border: 1.5px solid rgba(255,255,255,0.3);
      backdrop-filter: blur(8px);
    }

    .btn--ghost-white:hover {
      background: rgba(255,255,255,0.22);
      border-color: rgba(255,255,255,0.5);
      transform: translateY(-2px);
    }

    /* ============================================================
       SECTION BASE
    ============================================================ */
    .section {
      position: relative;
      z-index: 1;
      padding: clamp(4rem, 8vw, 8rem) 0;
      overflow: hidden;
    }

    .section--alt { background: var(--bg-secondary); }

    .section__label {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--coral);
      margin-bottom: 1.25rem;
    }

    .section__label::before {
      content: '';
      width: 20px; height: 2px;
      background: var(--coral);
      border-radius: 2px;
    }

    .section__title {
      font-family: var(--font-display);
      font-size: clamp(1.9rem, 3.5vw, 3rem);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.15;
      margin-bottom: 1.25rem;
    }

    .section__title span { color: var(--petrol); }

    /* Scroll reveal */
    .reveal {
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 0.8s cubic-bezier(0.25,0.46,0.45,0.94),
                  transform 0.8s cubic-bezier(0.25,0.46,0.45,0.94);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-left {
      opacity: 0;
      transform: translateX(-40px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .reveal-left.visible {
      opacity: 1;
      transform: translateX(0);
    }

    .reveal-right {
      opacity: 0;
      transform: translateX(40px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .reveal-right.visible {
      opacity: 1;
      transform: translateX(0);
    }

    /* ============================================================
       SOBRE SECTION
    ============================================================ */
    #sobre .container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2.5rem, 6vw, 6rem);
      align-items: center;
    }

    .sobre__content { }

    .sobre__text {
      color: var(--text-secondary);
      font-size: clamp(0.95rem, 1.4vw, 1.05rem);
      margin-bottom: 1rem;
      line-height: 1.8;
    }

    .sobre__highlight {
      display: inline-block;
      font-size: clamp(1rem, 1.5vw, 1.1rem);
      font-weight: 600;
      color: var(--petrol);
      font-family: var(--font-display);
      font-style: italic;
      margin-top: 0.75rem;
      padding-left: 1.25rem;
      border-left: 3px solid var(--coral);
    }

    .sobre__photo {
      position: relative;
    }

    .sobre__photo-frame {
      width: 100%;
      aspect-ratio: 3/4;
      border-radius: 40% 60% 55% 45% / 50% 45% 55% 50%;
      overflow: hidden;
      box-shadow: var(--shadow-medium);
      animation: morphSobre 14s ease-in-out infinite alternate;
    }

    @keyframes morphSobre {
      0%   { border-radius: 40% 60% 55% 45% / 50% 45% 55% 50%; }
      50%  { border-radius: 55% 45% 42% 58% / 44% 58% 42% 56%; }
      100% { border-radius: 48% 52% 60% 40% / 56% 40% 60% 44%; }
    }

    .sobre__photo-frame img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
    }

    .sobre__accent {
      position: absolute;
      bottom: -20px;
      left: -20px;
      width: 80px; height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--coral), var(--gold));
      opacity: 0.18;
      animation: floatAccent 6s ease-in-out infinite alternate;
      pointer-events: none;
    }

    .sobre__accent-2 {
      position: absolute;
      top: -16px;
      right: -16px;
      width: 48px; height: 48px;
      border-radius: 50%;
      background: var(--petrol);
      opacity: 0.12;
      animation: floatAccent 8s ease-in-out infinite alternate-reverse;
      pointer-events: none;
    }

    @keyframes floatAccent {
      0%   { transform: translate(0,0) scale(1); }
      100% { transform: translate(8px,-8px) scale(1.1); }
    }

    /* ============================================================
       SERVIÇOS SECTION — PARTITURA CRIATIVA
    ============================================================ */
    #servicos {
      background: var(--bg-secondary);
    }

    .servicos__header {
      text-align: center;
      max-width: 600px;
      margin: 0 auto 4rem;
    }

    .servicos__track {
      position: relative;
      padding: 3rem 0;
    }

    /* Staff lines like a music score */
    .servicos__staff {
      position: absolute;
      top: 50%;
      left: 0; right: 0;
      transform: translateY(-50%);
      height: 100%;
      pointer-events: none;
      overflow: hidden;
      opacity: 0.07;
    }

    .servicos__staff svg {
      width: 100%; height: 100%;
    }

    .servicos__items {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      position: relative;
      z-index: 2;
    }

    .servico-card {
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 1.5rem;
      padding: 2rem 1.5rem;
      position: relative;
      overflow: hidden;
      transition: transform var(--transition), box-shadow var(--transition);
      cursor: default;
    }

    .servico-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--petrol), var(--coral));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--transition);
    }

    .servico-card:hover::before { transform: scaleX(1); }

    .servico-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-medium);
    }

    .servico-card__icon {
      width: 52px; height: 52px;
      border-radius: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
      font-size: 1.5rem;
      background: linear-gradient(135deg, rgba(29,78,95,0.1), rgba(216,168,74,0.1));
      transition: transform var(--transition-fast);
    }

    .servico-card:hover .servico-card__icon {
      transform: scale(1.1) rotate(5deg);
    }

    .servico-card__number {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 700;
      color: var(--petrol);
      opacity: 0.06;
      line-height: 1;
      user-select: none;
    }

    .servico-card__title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }

    .servico-card__text {
      font-size: 0.875rem;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* Connector dots */
    .servicos__connector {
      display: none;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 100%;
      pointer-events: none;
      z-index: 1;
    }

    /* ============================================================
       GALERIA EDITORIAL
    ============================================================ */
    #galeria {
      background: var(--graphite);
      color: #fff;
      padding: clamp(4rem, 8vw, 8rem) 0;
    }

    [data-theme="dark"] #galeria {
      background: #0d1012;
    }

    .galeria__inner {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 0;
      position: relative;
      min-height: 600px;
    }

    .galeria__col-left {
      position: relative;
    }

    .galeria__col-right {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 3rem;
      padding: 3rem 3rem 3rem 4rem;
    }

    .galeria__photo {
      position: relative;
      overflow: hidden;
    }

    .galeria__photo-1 {
      width: 65%;
      margin-top: 3rem;
      margin-left: 0;
      border-radius: 0 2rem 2rem 0;
      aspect-ratio: 3/4;
      box-shadow: var(--shadow-strong);
      z-index: 2;
      position: relative;
    }

    .galeria__photo-2 {
      position: absolute;
      bottom: 4rem;
      right: -3rem;
      width: 55%;
      aspect-ratio: 4/5;
      border-radius: 2rem 0 0 2rem;
      box-shadow: var(--shadow-strong);
      z-index: 3;
    }

    .galeria__photo img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center;
      transition: transform 8s ease;
    }

    .galeria__photo:hover img { transform: scale(1.05); }

    .galeria__quote {
      position: relative;
      z-index: 4;
    }

    .galeria__quote-mark {
      font-family: var(--font-display);
      font-size: 5rem;
      line-height: 0.5;
      color: var(--coral);
      margin-bottom: 1rem;
      display: block;
      opacity: 0.6;
    }

    .galeria__quote-text {
      font-family: var(--font-display);
      font-size: clamp(1.44rem, 2.64vw, 2.16rem);
      font-weight: 400;
      font-style: italic;
      line-height: 1.4;
      color: rgba(255,255,255,0.92);
      text-align: center;
    }

    .galeria__quote-text strong {
      color: var(--gold);
      font-style: normal;
    }

    /* ============================================================
       ENSINO SECTION
    ============================================================ */
    #ensino {
      background: var(--bg-primary);
    }

    .ensino__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2.5rem, 6vw, 6rem);
      align-items: center;
    }

    .ensino__photo {
      position: relative;
      order: 2;
    }

    .ensino__photo-clip {
      width: 100%;
      aspect-ratio: 4/5;
      clip-path: polygon(8% 0%, 100% 0%, 92% 100%, 0% 100%);
      overflow: hidden;
      box-shadow: var(--shadow-medium);
    }

    .ensino__photo-clip img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
      transition: transform 8s ease;
    }

    .ensino__photo-clip:hover img { transform: scale(1.04); }

    .ensino__deco-line {
      position: absolute;
      top: 50%;
      right: -2rem;
      transform: translateY(-50%);
      width: 3px;
      height: 60%;
      background: linear-gradient(180deg, transparent, var(--coral), transparent);
      border-radius: 3px;
      pointer-events: none;
    }

    .ensino__content { order: 1; }

    .ensino__text {
      color: var(--text-secondary);
      font-size: clamp(0.95rem, 1.4vw, 1.05rem);
      line-height: 1.8;
      margin-bottom: 2rem;
    }

    .ensino__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .ensino__tag {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1.1rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 2rem;
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text-secondary);
      transition: all var(--transition-fast);
    }

    .ensino__tag:hover {
      background: var(--petrol);
      color: #fff;
      border-color: var(--petrol);
      transform: translateY(-2px);
    }

    .ensino__tag::before {
      content: '♩';
      color: var(--coral);
    }

    /* ============================================================
       BLOCO EMOCIONAL
    ============================================================ */
    #emocional {
      background: linear-gradient(145deg, var(--petrol) 0%, #0e3040 100%);
      padding: clamp(5rem, 10vw, 10rem) 0;
      position: relative;
      overflow: hidden;
    }

    [data-theme="dark"] #emocional {
      background: linear-gradient(145deg, #0a1e28 0%, #121416 100%);
    }

    .emocional__bg-wave {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .emocional__bg-wave svg {
      width: 100%; height: 100%;
      opacity: 0.06;
    }

    .emocional__glow-left {
      position: absolute;
      top: 20%;
      left: -10%;
      width: 40vw; height: 40vw;
      background: radial-gradient(circle, rgba(216,168,74,0.2) 0%, transparent 70%);
      pointer-events: none;
      animation: glowDrift 10s ease-in-out infinite alternate;
    }

    .emocional__glow-right {
      position: absolute;
      bottom: 10%;
      right: -10%;
      width: 35vw; height: 35vw;
      background: radial-gradient(circle, rgba(255,127,107,0.15) 0%, transparent 70%);
      pointer-events: none;
      animation: glowDrift 14s ease-in-out infinite alternate-reverse;
    }

    @keyframes glowDrift {
      0%   { transform: translate(0,0); }
      100% { transform: translate(5%, -5%); }
    }

    .emocional__content {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
    }

    .emocional__decor {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-bottom: 2.5rem;
    }

    .emocional__decor span {
      display: block;
      background: rgba(216,168,74,0.6);
      border-radius: 3px;
      animation: waveBounce var(--dur, 0.8s) ease-in-out infinite alternate;
    }

    .emocional__decor span:nth-child(1) { width: 3px; height: 12px; --dur: 0.8s; }
    .emocional__decor span:nth-child(2) { width: 3px; height: 24px; --dur: 0.6s; animation-delay: 0.1s; }
    .emocional__decor span:nth-child(3) { width: 3px; height: 38px; --dur: 0.9s; animation-delay: 0.2s; }
    .emocional__decor span:nth-child(4) { width: 3px; height: 28px; --dur: 0.7s; animation-delay: 0.15s; }
    .emocional__decor span:nth-child(5) { width: 3px; height: 44px; --dur: 1.0s; animation-delay: 0.05s; }
    .emocional__decor span:nth-child(6) { width: 3px; height: 32px; --dur: 0.75s; animation-delay: 0.3s; }
    .emocional__decor span:nth-child(7) { width: 3px; height: 20px; --dur: 0.85s; animation-delay: 0.25s; }
    .emocional__decor span:nth-child(8) { width: 3px; height: 38px; --dur: 0.65s; animation-delay: 0.1s; }
    .emocional__decor span:nth-child(9) { width: 3px; height: 24px; --dur: 0.95s; animation-delay: 0.2s; }
    .emocional__decor span:nth-child(10) { width: 3px; height: 14px; --dur: 0.8s; animation-delay: 0.35s; }

    .emocional__quote {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 3.5vw, 3rem);
      font-weight: 400;
      font-style: italic;
      color: rgba(255,255,255,0.95);
      line-height: 1.4;
      letter-spacing: -0.01em;
    }

    .emocional__quote em {
      font-style: normal;
      color: var(--gold);
    }

    .emocional__author {
      margin-top: 2rem;
      font-size: 0.8rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
    }

    /* ============================================================
       CTA FINAL
    ============================================================ */
    #contato {
      background: var(--bg-secondary);
    }

    .cta__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2.5rem, 5vw, 5rem);
      align-items: center;
    }

    .cta__content { }

    .cta__title {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3.2vw, 2.8rem);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.2;
      margin-bottom: 1.25rem;
    }

    .cta__title span { color: var(--coral); }

    .cta__text {
      font-size: clamp(0.95rem, 1.4vw, 1.05rem);
      color: var(--text-secondary);
      margin-bottom: 2rem;
      line-height: 1.7;
    }

    .cta__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .cta__visual {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .cta__info-card {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem 1.5rem;
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 1rem;
      transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .cta__info-card:hover {
      transform: translateX(6px);
      box-shadow: var(--shadow-soft);
    }

    .cta__info-icon {
      width: 44px; height: 44px;
      border-radius: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }

    .cta__info-icon--wa  { background: rgba(37,211,102,0.1); color: #25D366; }
    .cta__info-icon--ig  { background: rgba(255,127,107,0.1); color: var(--coral); }

    .cta__info-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--text-muted);
      margin-bottom: 0.2rem;
    }

    .cta__info-value {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    /* ============================================================
       FOOTER
    ============================================================ */
    footer {
      background: var(--graphite);
      color: rgba(255,255,255,0.85);
      padding: clamp(3rem, 6vw, 5rem) 0 0;
    }

    [data-theme="dark"] footer {
      background: #0a0c0e;
    }

    .footer__inner {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .footer__brand {}

    .footer__logo {
      height: 48px;
      width: auto;
      margin-bottom: 1.25rem;
      filter: brightness(1.15) contrast(1.05);
    }

    .footer__tagline {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .footer__social {
      display: flex;
      gap: 0.625rem;
    }

    .footer__social-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 38px; height: 38px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.15);
      color: rgba(255,255,255,0.6);
      transition: all var(--transition-fast);
      font-size: 0.9rem;
    }

    .footer__social-link:hover {
      background: var(--coral);
      border-color: var(--coral);
      color: #fff;
      transform: translateY(-2px);
    }

    .footer__col-title {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 1.25rem;
    }

    .footer__contact-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-bottom: 0.875rem;
    }

    .footer__contact-item svg {
      margin-top: 2px;
      flex-shrink: 0;
      opacity: 0.5;
    }

    .footer__contact-item a {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.7);
      transition: color var(--transition-fast);
    }

    .footer__contact-item a:hover { color: var(--coral); }

    .footer__nav-list { list-style: none; }

    .footer__nav-list li { margin-bottom: 0.75rem; }

    .footer__nav-list a {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.6);
      transition: color var(--transition-fast);
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
    }

    .footer__nav-list a::before {
      content: '—';
      font-size: 0.65rem;
      opacity: 0.4;
    }

    .footer__nav-list a:hover { color: var(--coral); }

    .footer__bottom {
      padding: 1.5rem 0;
      text-align: center;
    }

    .footer__copy {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.25);
    }

    /* =====================================================
   BUNKER DIGITAL - RODAPÉ PREMIUM DESTACADO
   ===================================================== */

    .bunker-sig{
      background:#0a0c0e;
      border-top:1px solid rgba(255,255,255,.04);
      padding:1.75rem 0;
    }

    [data-theme="light"] .bunker-sig{
      background:#1a1e21;
    }

    .bunker-sig__inner{
      display:flex;
      justify-content:center;
    }

    .bunker-sig__link{
      display:inline-flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:12px;
      padding:18px 32px;
      border:1px solid rgba(196,168,232,.25);
      border-radius:18px;
      position:relative;
      overflow:hidden;
      transition:border-color .35s ease, box-shadow .35s ease, transform .35s ease;
    }

    .bunker-sig__link::before{
      content:"";
      position:absolute;
      inset:0;
      border-radius:18px;
      box-shadow:0 0 12px rgba(196,168,232,.20),
                 0 0 24px rgba(196,168,232,.12),
                 0 0 36px rgba(196,168,232,.08);
      opacity:0;
      transition:opacity .35s ease;
      pointer-events:none;
    }

    .bunker-sig__link:hover{
      border-color:rgba(196,168,232,.65);
      box-shadow:0 0 10px rgba(196,168,232,.15),
                 0 0 22px rgba(196,168,232,.10);
      transform:translateY(-2px);
    }

    .bunker-sig__link:hover::before{
      opacity:1;
    }

    .bunker-sig__logo{
      width:auto;
      height:53px;
      max-width:196px;
      opacity:.88;
      transition:opacity .35s ease, transform .35s ease;
      filter:brightness(1.2);
    }

    .bunker-sig__link:hover .bunker-sig__logo{
      opacity:1;
      transform:scale(1.04);
    }

    .bunker-sig__text{
      font-size:14.3px;
      font-weight:500;
      letter-spacing:.14em;
      text-transform:uppercase;
      color:rgba(255,255,255,.45);
      transition:color .35s ease;
    }

    .bunker-sig__link:hover .bunker-sig__text{
      color:rgba(255,255,255,.75);
    }

    /* ============================================================
       ANIMATIONS
    ============================================================ */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* ============================================================
       SCROLLBAR
    ============================================================ */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg-primary); }
    ::-webkit-scrollbar-thumb {
      background: var(--petrol);
      border-radius: 3px;
      opacity: 0.4;
    }
    ::-webkit-scrollbar-thumb:hover { background: var(--coral); }

    /* ============================================================
       RESPONSIVE — Tablet
    ============================================================ */
    @media (max-width: 1024px) {
      .servicos__items {
        grid-template-columns: repeat(2, 1fr);
      }

      .footer__inner {
        grid-template-columns: 1fr 1fr;
      }

      .footer__brand {
        grid-column: 1 / -1;
      }

      .galeria__inner {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .galeria__col-left {
        position: relative;
        height: 400px;
      }

      .galeria__photo-1 {
        width: 50%;
        border-radius: 0 1.5rem 1.5rem 0;
      }

      .galeria__photo-2 {
        right: 0;
        width: 48%;
        border-radius: 1.5rem 0 0 1.5rem;
        bottom: 2rem;
      }

      .galeria__col-right {
        padding: 3rem 1.5rem;
        gap: 2rem;
      }
    }

    /* ============================================================
       RESPONSIVE — Mobile
    ============================================================ */
    @media (max-width: 768px) {
      .hamburger { display: flex; }
      .nav__menu, .btn-nav-wa { display: none; }
      .nav__mobile { display: flex; }

      #inicio {
        grid-template-columns: 1fr;
        min-height: auto;
        padding-top: 6rem;
        padding-bottom: 3rem;
      }

      .hero__left {
        padding: 1.5rem 1.25rem 2rem;
        text-align: center;
      }

      .hero__eyebrow {
        justify-content: center;
      }

      .hero__text { max-width: 100%; }

      .hero__ctas {
        justify-content: center;
      }

      .hero__wave-deco {
        justify-content: center;
      }

      .hero__right {
        padding: 0 1.25rem 3rem;
        order: -1;
      }

      .hero__photo-wrap {
        width: clamp(220px, 72vw, 340px);
      }

      #sobre .container,
      .cta__inner {
        grid-template-columns: 1fr;
      }

      .sobre__photo { order: -1; }

      .sobre__photo-frame {
        width: 70%;
        margin: 0 auto;
      }

      .ensino__inner {
        grid-template-columns: 1fr;
      }

      .ensino__photo { order: -1; }

      .ensino__photo-clip {
        width: 80%;
        margin: 0 auto;
      }

      .ensino__deco-line { display: none; }

      .servicos__items {
        grid-template-columns: 1fr;
      }

      .footer__inner {
        grid-template-columns: 1fr;
      }

      .galeria__col-left { height: 320px; }

      .galeria__photo-1 {
        width: 60%;
        margin-top: 2rem;
      }

      .galeria__photo-2 {
        width: 55%;
        bottom: 1.5rem;
        right: 0;
      }

      .galeria__col-right {
        padding: 2rem 1.25rem;
      }

      .cta__visual { display: none; }
    }

    @media (max-width: 480px) {
      .btn { padding: 0.75rem 1.4rem; font-size: 0.85rem; }

      .hero__ctas { flex-direction: column; align-items: center; }
      .hero__ctas .btn { width: 100%; justify-content: center; max-width: 280px; }
    }

    /* ============================================================
       FOCUS & ACCESSIBILITY
    ============================================================ */
    :focus-visible {
      outline: 2px solid var(--petrol);
      outline-offset: 3px;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>

